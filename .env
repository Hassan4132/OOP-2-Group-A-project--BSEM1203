# ============================================================
# Clinic Service API - Environment Configuration
# ============================================================
# Copy this file to .env and update the values as needed.

# --- Database Configuration ---
DATABASE_URL=sqlite:///./clinic.db

# --- JWT Authentication ---
SECRET_KEY=clinic-api-super-secret-key-change-this-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Application Settings ---
APP_NAME=Clinic Service API
APP_VERSION=1.0.0
DEBUG=True

# --- Upload Settings ---
UPLOAD_DIR=app/uploads
MAX_UPLOAD_SIZE_MB=5
